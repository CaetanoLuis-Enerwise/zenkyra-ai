# Copy to `.env` and fill secrets.
APP_ENV=development
DEBUG=false

# JWT — minimum 32 chars
SECRET_KEY=change-me-use-openssl-rand-hex-32-in-production-min-32chars

# PostgreSQL (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://zenkyra:zenkyra@localhost:5432/zenkyra

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Google Gemini (required)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
LLM_PROVIDER=gemini

# Dev convenience — auto-create tables (disable in production; use Alembic)
DATABASE_BOOTSTRAP=true

# Local file storage for uploads
STORAGE_PATH=./storage
